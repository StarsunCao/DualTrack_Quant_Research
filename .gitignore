# IDE 与编辑器配置
.idea/
*.iml
.vscode/
.claude/  # Claude Code 工作目录

# 环境变量（包含 API 密钥，绝对禁止提交）
.env
.env.local
.env.*.local

# Python 环境与缓存
__pycache__/
.venv/
.uv/

# 数据与结果（防止几GB的CSV把GitHub撑爆）
data/
results/
*.csv
*.log

# macOS 系统临时文件
.DS_Store

# 后缀名补充
*.pdf
*.png
*.jpg
# 理由：Backtrader 绘图生成的静态图表通常作为论文插图，不建议直接放进 Git 仓库。

# 潜在的大模型文件
*.gguf
# 理由：虽然你目前用 Ollama 集中管理模型，但如果你以后下载了独立的量化模型文件，此规则可防止误传。

# ============================================================================
# 运行时生成的文件（每次回测都会重新生成，不应提交）
# ============================================================================

# LLM 缓存（大文件，可重新生成）
docs/cache/**/
!docs/cache/.gitkeep

# 回测输出（每次运行都会变）
docs/output/**/
!docs/output/.gitkeep

# 图表（论文插图建议单独存储，不提交到Git）
# *.png 已在上面配置

# 测试生成的临时文件
tests/test_outputs/
.pytest_cache/
.coverage
htmlcov/

# 临时测试文件
test_*.py
!tests/

# 备份文件
*_backup.jsonl
*_backup.*

# 临时测试文件
test_*.py
!tests/

# 备份文件
*_backup.jsonl
*_backup.*
