# IDE 与编辑器配置
.idea/
*.iml
.vscode/
.claude/  # Claude Code 工作目录

# 环境变量（包含 API 密钥，绝对禁止提交）
.env
.env.local
.env.*.local

# Python 环境与缓存
__pycache__/
.venv/
.uv/

# 数据与结果（防止几GB的CSV把GitHub撑爆）
data/
results/
*.csv
*.log

# macOS 系统临时文件
.DS_Store

# 训练生成的模型文件（体积大，可重新训练）
models/

# 后缀名补充
*.pdf
*.png
*.jpg

# 潜在的大模型文件
*.gguf

# ============================================================================
# 运行时生成的文件（每次回测都会重新生成，不应提交）
# ============================================================================

# 回测运行时生成的文件（每次运行都会重新生成）
docs/

# 分析脚本运行时生成的输出
output/

# 测试生成的临时文件
tests/test_outputs/
.pytest_cache/
.coverage
htmlcov/

# 临时测试文件（仅根目录）
/test_*.py
/analyze_*.py

# 备份文件
*_backup.jsonl
*_backup.*

# 论文相关
thesis/